{
  "info": {
    "name": "RealSync/Nagfy — Property Module Phase 1",
    "_postman_id": "realsync-property-module-phase-1",
    "description": "Postman collection test API Property Module Phase 1.\n\nCách dùng nhanh:\n1. Import collection này vào Postman.\n2. Chạy `Auth/Login — Admin` để tự lưu accessToken.\n3. Chạy `Lookup/Get Property Types` và `Lookup/Get Provinces` để tự lưu typeId/provinceId.\n4. Có thể chạy `Categories/Create Test Category` để tự lưu categoryId.\n5. Chạy `Properties/Create Property`, sau đó các request detail/update/delete/upload image sẽ dùng propertyId vừa lưu.\n\nTài khoản seed:\n- admin@realsync.vn / Admin@123\n- cuong@realsync.vn / Cuong@123\n- loc@realsync.vn / Loc@123\n- danh@realsync.vn / Danh@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5178/api/v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "propertyId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "typeId",
      "value": "",
      "type": "string"
    },
    {
      "key": "provinceId",
      "value": "",
      "type": "string"
    },
    {
      "key": "districtId",
      "value": "",
      "type": "string"
    },
    {
      "key": "wardId",
      "value": "",
      "type": "string"
    },
    {
      "key": "imageId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login — Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login success', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken || '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@realsync.vn\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Lookup",
      "item": [
        {
          "name": "Get Property Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Categories response ok', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('categoryId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/property-categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "property-categories"
              ]
            }
          }
        },
        {
          "name": "Get Property Types",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Types response ok', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('typeId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/property-types",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "property-types"
              ]
            }
          }
        },
        {
          "name": "Get Provinces",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Provinces response ok', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('provinceId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/locations/provinces",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "locations",
                "provinces"
              ]
            }
          }
        },
        {
          "name": "Get Districts By Province",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Districts response ok', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('districtId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/locations/districts?provinceId={{provinceId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "locations",
                "districts"
              ],
              "query": [
                {
                  "key": "provinceId",
                  "value": "{{provinceId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Wards By District",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Wards response ok', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('wardId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/locations/wards?districtId={{districtId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "locations",
                "wards"
              ],
              "query": [
                {
                  "key": "districtId",
                  "value": "{{districtId}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Test Category",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('categorySlug', 'test-category-' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create category success', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('categoryId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Danh mục test Postman\",\n  \"slug\": \"{{categorySlug}}\",\n  \"description\": \"Danh mục dùng để test Property Module\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/property-categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "property-categories"
              ]
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Danh mục test Postman Updated\",\n  \"description\": \"Đã cập nhật bằng Postman\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/property-categories/{{categoryId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "property-categories",
                "{{categoryId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/property-categories/{{categoryId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "property-categories",
                "{{categoryId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Properties",
      "item": [
        {
          "name": "Get Properties — Search Filter Sort Page",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/properties?page=1&pageSize=10&search=test&minPrice=0&maxPrice=10000000000&minArea=0&maxArea=500&provinceId={{provinceId}}&categoryId={{categoryId}}&typeId={{typeId}}&status=Draft&sortBy=createdAt&sortDirection=desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "properties"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": "test"
                },
                {
                  "key": "minPrice",
                  "value": "0"
                },
                {
                  "key": "maxPrice",
                  "value": "10000000000"
                },
                {
                  "key": "minArea",
                  "value": "0"
                },
                {
                  "key": "maxArea",
                  "value": "500"
                },
                {
                  "key": "provinceId",
                  "value": "{{provinceId}}"
                },
                {
                  "key": "categoryId",
                  "value": "{{categoryId}}"
                },
                {
                  "key": "typeId",
                  "value": "{{typeId}}"
                },
                {
                  "key": "status",
                  "value": "Draft"
                },
                {
                  "key": "sortBy",
                  "value": "createdAt"
                },
                {
                  "key": "sortDirection",
                  "value": "desc"
                }
              ]
            }
          }
        },
        {
          "name": "Create Property",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('propertyCode', 'PM-' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create property success', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('propertyId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Nhà phố test Postman\",\n  \"description\": \"Bất động sản tạo từ Postman collection\",\n  \"code\": \"{{propertyCode}}\",\n  \"price\": 3500000000,\n  \"area\": 80,\n  \"priceUnit\": \"VND\",\n  \"address\": \"123 Nguyễn Huệ\",\n  \"provinceId\": \"{{provinceId}}\",\n  \"propertyCategoryId\": \"{{categoryId}}\",\n  \"propertyTypeId\": \"{{typeId}}\",\n  \"status\": \"Draft\",\n  \"listingType\": \"Sale\",\n  \"bedrooms\": 3,\n  \"bathrooms\": 2,\n  \"floors\": 2,\n  \"direction\": \"Đông\",\n  \"legalStatus\": \"Sổ hồng\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/properties",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "properties"
              ]
            }
          }
        },
        {
          "name": "Get Property Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "properties",
                "{{propertyId}}"
              ]
            }
          }
        },
        {
          "name": "Update Property",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Nhà phố test Postman Updated\",\n  \"price\": 3650000000,\n  \"area\": 85,\n  \"address\": \"456 Lê Lợi\",\n  \"provinceId\": \"{{provinceId}}\",\n  \"propertyCategoryId\": \"{{categoryId}}\",\n  \"propertyTypeId\": \"{{typeId}}\",\n  \"status\": \"Available\",\n  \"listingType\": \"Sale\",\n  \"bedrooms\": 4,\n  \"bathrooms\": 3,\n  \"floors\": 3,\n  \"direction\": \"Nam\",\n  \"legalStatus\": \"Sổ hồng riêng\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "properties",
                "{{propertyId}}"
              ]
            }
          }
        },
        {
          "name": "Upload Property Images",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Upload image success', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('imageId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}/images",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "properties",
                "{{propertyId}}",
                "images"
              ]
            },
            "description": "Trong Postman, chọn tab Body > form-data > key `files` type File, rồi chọn một hoặc nhiều ảnh .jpg/.jpeg/.png/.webp."
          }
        },
        {
          "name": "Set Thumbnail",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}/images/{{imageId}}/thumbnail",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "properties",
                "{{propertyId}}",
                "images",
                "{{imageId}}",
                "thumbnail"
              ]
            }
          }
        },
        {
          "name": "Delete Image",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}/images/{{imageId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "properties",
                "{{propertyId}}",
                "images",
                "{{imageId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Property",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "properties",
                "{{propertyId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": {
              "raw": "http://localhost:5178/health",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5178",
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    }
  ]
}
