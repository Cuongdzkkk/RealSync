    {
      "name": "📢 Posting Management",
      "item": [
        {
          "name": "📝 Posts",
          "item": [
            {
              "name": "Create Post",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "    var json = pm.response.json();",
                      "    pm.collectionVariables.set('currentPostId', json.data.id);",
                      "    console.log('✅ currentPostId saved: ' + json.data.id);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Căn hộ cao cấp Vinhomes Grand Park 2PN2WC giá cực tốt\",\n  \"content\": \"Bán căn hộ Vinhomes Grand Park, Quận 9 cũ. Diện tích 69m2, thiết kế 2 phòng ngủ, 2 nhà vệ sinh. Full nội thất cao cấp chỉ xách vali vào ở. View trực diện công viên 36ha cực đẹp. Sổ hồng riêng sẵn sàng giao dịch ngay.\",\n  \"summary\": \"Căn hộ Vinhomes Grand Park 2PN 69m2 full nội thất view công viên 36ha giá tốt.\",\n  \"thumbnailUrl\": \"https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=800\",\n  \"propertyId\": null\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/posts",
                  "host": ["{{baseUrl}}"],
                  "path": ["posts"]
                },
                "description": "Tạo bài đăng BĐS mới. Tự động lưu currentPostId vào biến môi trường."
              }
            },
            {
              "name": "Get List Posts",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/posts?page=1&pageSize=10&status=Draft",
                  "host": ["{{baseUrl}}"],
                  "path": ["posts"],
                  "query": [
                    { "key": "page", "value": "1" },
                    { "key": "pageSize", "value": "10" },
                    { "key": "status", "value": "Draft", "description": "Lọc theo trạng thái: Draft, Scheduled, Published, Failed, Archived (Không bắt buộc)" },
                    { "key": "search", "value": "Vinhomes", "disabled": true, "description": "Tìm kiếm theo tiêu đề/nội dung (Không bắt buộc)" }
                  ]
                },
                "description": "Lấy danh sách bài đăng có phân trang và filter."
              }
            },
            {
              "name": "Get Post By ID",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/posts/{{currentPostId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["posts", "{{currentPostId}}"]
                },
                "description": "Lấy thông tin chi tiết một bài đăng."
              }
            },
            {
              "name": "Update Post",
              "request": {
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"[Cập nhật] Căn hộ Vinhomes Grand Park 2PN full nội thất view 36ha\",\n  \"content\": \"Cập nhật: Bán căn hộ Vinhomes Grand Park, Quận 9. Diện tích 69m2, 2PN, 2WC. Hỗ trợ vay ngân hàng 70%, ân hạn gốc lãi. View nội khu và hồ bơi thoáng mát. Liên hệ xem nhà 24/7.\",\n  \"summary\": \"Căn hộ Vinhomes Grand Park 2PN full nội thất view đẹp hỗ trợ vay.\",\n  \"thumbnailUrl\": \"https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=800\",\n  \"propertyId\": null\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/posts/{{currentPostId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["posts", "{{currentPostId}}"]
                },
                "description": "Cập nhật tiêu đề, nội dung, ảnh đại diện của bài đăng."
              }
            },
            {
              "name": "Update Post Status",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"status\": \"Published\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/posts/{{currentPostId}}/status",
                  "host": ["{{baseUrl}}"],
                  "path": ["posts", "{{currentPostId}}", "status"]
                },
                "description": "Cập nhật nhanh trạng thái bài đăng. Giá trị hợp lệ: Draft, Scheduled, Published, Failed, Archived."
              }
            },
            {
              "name": "Delete Post",
              "request": {
                "method": "DELETE",
                "url": {
                  "raw": "{{baseUrl}}/posts/{{currentPostId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["posts", "{{currentPostId}}"]
                },
                "description": "Xóa mềm bài đăng (IsDeleted = true)."
              }
            }
          ]
        },
