      "key": "baseUrl",
      "value": "http://localhost:5178/api/v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "currentPostId",
      "value": "",
      "type": "string"
    },
    {
      "key": "currentChannelId",
      "value": "",
      "type": "string"
    },
    {
      "key": "currentScheduleId",
      "value": "",
      "type": "string"
    },
    {
      "key": "currentAiContentId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login — Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "    console.log('✅ Token saved! Role: Admin');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@realsync.vn\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Đăng nhập Admin. Token tự động lưu vào collection variables."
          }
