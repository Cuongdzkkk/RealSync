              }
            },
            {
              "name": "Delete Channel",
              "request": {
                "method": "DELETE",
                "url": {
                  "raw": "{{baseUrl}}/posts/{{currentPostId}}/channels/{{currentChannelId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["posts", "{{currentPostId}}", "channels", "{{currentChannelId}}"]
                },
                "description": "Hủy liên kết kênh đăng bài khỏi bài viết."
              }
            }
          ]
        },
